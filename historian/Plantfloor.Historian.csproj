<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Always run with the historian folder as the working directory, no matter where
         "dotnet run" was launched from. Without this, the relative plantfloor.db path
         lands in whatever folder you happened to be standing in (found out 2026-07-14). -->
    <RunWorkingDirectory>$(MSBuildProjectDirectory)</RunWorkingDirectory>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.9" />
    <PackageReference Include="MQTTnet" Version="5.2.0.1603" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
  </ItemGroup>

</Project>
